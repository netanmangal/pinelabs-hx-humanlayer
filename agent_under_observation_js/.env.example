# Amazon Bedrock (IAM user with AmazonBedrockFullAccess)
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1

# PineLabs Agent Toolkit (from developer.pinelabsonline.com)
PINE_CLIENT_ID=your_pine_client_id
PINE_CLIENT_SECRET=your_pine_client_secret
PINELABS_MID=your_merchant_id

# HumanLayer (from your dashboard → Settings → API Keys)
HUMANLAYER_API_KEY=adr_your_api_key
HUMANLAYER_PROJECT_ID=pinelabs-commerce-agent
HUMANLAYER_API_BASE_URL=http://localhost:8001
HUMANLAYER_DEBUG=false

# Optional: override session name (used by backend /api/agent/invoke)
# AGENT_SESSION_NAME=commerce-demo-001
