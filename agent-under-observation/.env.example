# Copy this file to .env and fill in your real values

# LLM Provider
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Cal.com Calendar API (v2)
CALCOM_CALENDAR_API_KEY=cal_live_...

# GitHub Personal Access Token
# Required scopes: repo, issues, read:user
GITHUB_PERSONAL_ACCESS_TOKEN=github_pat_...
GITHUB_DEFAULT_REPO=owner/repo-name

# Supabase PostgreSQL
SUPABASE_PROJECT_URL=https://<project-id>.supabase.co
SUPABASE_PUB_KEY=sb_publishable_...
SUPABASE_DB_PASSWORD=...
SUPABASE_SESSION_POOLER_URL=postgresql://postgres.<project-id>:<password>@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres
